# Aggregates SQLite (built by ETL, read-only at runtime)
H1B_DATA_DB=data/h1b_data.db

# User data — Postgres in production; sqlite fallback for local dev
DATABASE_URL=sqlite:///data/users.db

# Auth / email
RESEND_API_KEY=
EMAIL_FROM=otp@your-domain.dev
OTP_SECRET=change-me-in-production

# Demo employer canonical name (must exist in h1b_data.db)
DEMO_EMPLOYER=DATADOG

# Optional — Phase 2 deploy / Phase 4 monitoring
SIMPLE_ANALYTICS=0
SENTRY_DSN=
